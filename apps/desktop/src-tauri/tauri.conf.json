{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "resound",
  "version": "0.1.0",
  "identifier": "com.resound.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Resound",
        "label": "main",
        "width": 800,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      },
      {
        "title": "Tray",
        "label": "tray",
        "width": 320,
        "height": 420,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
